<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEEEEE">

    <com.example.rollingcoin.SimulationView
        android:id="@+id/simulationView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/settingsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CCFFFFFF"
        android:orientation="vertical">

        <!-- Header / Toggle Area -->
        <LinearLayout
            android:id="@+id/toggleHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="8dp"
            android:background="#DDDDDD">
            <TextView
                android:id="@+id/toggleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EINSTELLUNGEN AUSBLENDEN"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Collapsible Content -->
        <LinearLayout
            android:id="@+id/collapsibleContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Anzahl Münzen"
                    android:textColor="#000000"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/countValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#000000"
                    android:text="1" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/countSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:min="1"
                android:max="10" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Lautstärke"
                    android:textColor="#000000"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/volumeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#000000"
                    android:text="50%" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/volumeSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100" />

            <!-- Audio Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <Button
                        android:id="@+id/btnRecordImpact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Rec Impact"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:backgroundTint="#DDDDDD"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                    <Button
                        android:id="@+id/btnLoadImpact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Load Impact"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:backgroundTint="#DDDDDD"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                </LinearLayout>

                <Space android:layout_width="8dp" android:layout_height="wrap_content" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <Button
                        android:id="@+id/btnRecordScrape"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Rec Scrape"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:backgroundTint="#DDDDDD"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                    <Button
                        android:id="@+id/btnLoadScrape"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Load Scrape"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:backgroundTint="#DDDDDD"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Radius"
                    android:textColor="#000000"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/radiusValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#000000"
                    android:text="30%" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/radiusSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Gleiten"
                    android:textColor="#000000"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/glideValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#000000"
                    android:text="30%" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/glideSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Vibration"
                    android:textColor="#000000"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/vibrationValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#000000"
                    android:text="80%" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/vibrationSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100" />

        </LinearLayout>
    </LinearLayout>
</FrameLayout>