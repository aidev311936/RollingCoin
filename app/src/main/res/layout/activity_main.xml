<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEEEEE">

    <com.example.rollingcoin.SimulationView
        android:id="@+id/simulationView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/settingsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CCFFFFFF"
        android:orientation="vertical">

        <!-- Header / Toggle Area -->
        <LinearLayout
            android:id="@+id/toggleHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="8dp"
            android:background="#DDDDDD">
            <TextView
                android:id="@+id/toggleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EINSTELLUNGEN AUSBLENDEN"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Collapsible Content -->
        <LinearLayout
            android:id="@+id/collapsibleContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Anzahl Münzen"
                android:textColor="#000000"
                android:textStyle="bold"
                android:paddingBottom="2dp" />

            <!-- 1 ct -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="1 ct" android:textColor="#000000" android:textSize="12sp" />
                <SeekBar android:id="@+id/slider_1ct" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:max="10" />
                <TextView android:id="@+id/count_1ct" android:layout_width="20dp" android:layout_height="wrap_content" android:text="0" android:textColor="#000000" android:gravity="center" android:textSize="12sp" />
            </LinearLayout>
            <!-- 2 ct -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="2 ct" android:textColor="#000000" android:textSize="12sp" />
                <SeekBar android:id="@+id/slider_2ct" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:max="10" />
                <TextView android:id="@+id/count_2ct" android:layout_width="20dp" android:layout_height="wrap_content" android:text="0" android:textColor="#000000" android:gravity="center" android:textSize="12sp" />
            </LinearLayout>
            <!-- 5 ct -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="5 ct" android:textColor="#000000" android:textSize="12sp" />
                <SeekBar android:id="@+id/slider_5ct" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:max="10" />
                <TextView android:id="@+id/count_5ct" android:layout_width="20dp" android:layout_height="wrap_content" android:text="0" android:textColor="#000000" android:gravity="center" android:textSize="12sp" />
            </LinearLayout>
            <!-- 10 ct -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="10 ct" android:textColor="#000000" android:textSize="12sp" />
                <SeekBar android:id="@+id/slider_10ct" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:max="10" />
                <TextView android:id="@+id/count_10ct" android:layout_width="20dp" android:layout_height="wrap_content" android:text="0" android:textColor="#000000" android:gravity="center" android:textSize="12sp" />
            </LinearLayout>
            <!-- 20 ct -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="20 ct" android:textColor="#000000" android:textSize="12sp" />
                <SeekBar android:id="@+id/slider_20ct" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:max="10" />
                <TextView android:id="@+id/count_20ct" android:layout_width="20dp" android:layout_height="wrap_content" android:text="0" android:textColor="#000000" android:gravity="center" android:textSize="12sp" />
            </LinearLayout>
            <!-- 50 ct -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="50 ct" android:textColor="#000000" android:textSize="12sp" />
                <SeekBar android:id="@+id/slider_50ct" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:max="10" />
                <TextView android:id="@+id/count_50ct" android:layout_width="20dp" android:layout_height="wrap_content" android:text="0" android:textColor="#000000" android:gravity="center" android:textSize="12sp" />
            </LinearLayout>
            <!-- 1 € -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="1 €" android:textColor="#000000" android:textSize="12sp" />
                <SeekBar android:id="@+id/slider_1eu" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:max="10" />
                <TextView android:id="@+id/count_1eu" android:layout_width="20dp" android:layout_height="wrap_content" android:text="0" android:textColor="#000000" android:gravity="center" android:textSize="12sp" />
            </LinearLayout>
            <!-- 2 € -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="2 €" android:textColor="#000000" android:textSize="12sp" />
                <SeekBar android:id="@+id/slider_2eu" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:max="10" />
                <TextView android:id="@+id/count_2eu" android:layout_width="20dp" android:layout_height="wrap_content" android:text="0" android:textColor="#000000" android:gravity="center" android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Lautstärke"
                    android:textColor="#000000"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/volumeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#000000"
                    android:text="50%" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/volumeSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100" />

            <!-- Audio Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <Button
                        android:id="@+id/btnRecordImpact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Rec Impact"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:backgroundTint="#DDDDDD"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                    <Button
                        android:id="@+id/btnLoadImpact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Load Impact"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:backgroundTint="#DDDDDD"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                    <Button
                        android:id="@+id/btnResetImpact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Reset Impact"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:backgroundTint="#DDDDDD"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                </LinearLayout>

                <Space android:layout_width="8dp" android:layout_height="wrap_content" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <Button
                        android:id="@+id/btnRecordScrape"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Rec Scrape"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:backgroundTint="#DDDDDD"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                    <Button
                        android:id="@+id/btnLoadScrape"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Load Scrape"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:backgroundTint="#DDDDDD"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                    <Button
                        android:id="@+id/btnResetScrape"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Reset Scrape"
                        android:textSize="10sp"
                        android:textColor="#000000"
                        android:backgroundTint="#DDDDDD"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Radius"
                    android:textColor="#000000"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/radiusValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#000000"
                    android:text="30%" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/radiusSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Gleiten"
                    android:textColor="#000000"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/glideValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#000000"
                    android:text="30%" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/glideSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Vibration"
                    android:textColor="#000000"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/vibrationValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#000000"
                    android:text="80%" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/vibrationSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100" />

        </LinearLayout>
    </LinearLayout>
</FrameLayout>